# activia-trace — Configuración base del backend
# Copiar a .env y completar con valores reales (nunca comitear .env)

# PostgreSQL connection (async via asyncpg)
DATABASE_URL="postgresql+asyncpg://trace:trace@localhost:5435/trace"

# PostgreSQL connection for tests (separate DB)
DATABASE_URL_TEST="postgresql+asyncpg://trace:trace@localhost:5435/trace_test"

# JWT signing key — mínimo 32 caracteres, generar con: openssl rand -hex 32
SECRET_KEY="change-me-to-a-random-secret-at-least-32-chars"

# AES-256 encryption key for PII/secretos — exactamente 32 caracteres
ENCRYPTION_KEY="a0b1c2d3e4f5g6h7i8j9k0l1m2n3o4p5"

# Access token expiration in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15
